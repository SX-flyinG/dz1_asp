@model homework_project.Models.Product
@{
    ViewData["Title"] = "Додати продукт";
    ViewData["Active"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="breadcrumb">
    <a href="/Product/Index">Продукти</a>
    <span>›</span>
    Новий продукт
</div>
<br>

<div class="page-header">
    <h1>➕ Додати продукт</h1>
    <p>Заповніть форму для додавання нового продукту в каталог</p>
</div>

<div class="card">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Name">Назва продукту *</label>
            <input asp-for="Name" class="form-control" placeholder="Наприклад: Ноутбук Dell XPS 15" />
            <span asp-validation-for="Name" class="field-validation-error"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="Category">Категорія *</label>
                <select asp-for="Category" class="form-control">
                    <option value="">— Оберіть категорію —</option>
                    <option>Електроніка</option>
                    <option>Побутова техніка</option>
                    <option>Аудіо</option>
                    <option>Комп'ютери</option>
                    <option>Телефони</option>
                    <option>Одяг</option>
                    <option>Продукти харчування</option>
                    <option>Інше</option>
                </select>
                <span asp-validation-for="Category" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="Price">Ціна (грн) *</label>
                <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                <span asp-validation-for="Price" class="field-validation-error"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Stock">Кількість на складі</label>
            <input asp-for="Stock" type="number" min="0" class="form-control" placeholder="0" />
            <span asp-validation-for="Stock" class="field-validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description">Опис продукту</label>
            <textarea asp-for="Description" class="form-control" placeholder="Короткий опис продукту..."></textarea>
        </div>

        <div style="display:flex; gap:12px; margin-top:0.5rem">
            <button type="submit" class="btn btn-primary">Зберегти продукт</button>
            <a href="/Product/Index" class="btn btn-secondary">Скасувати</a>
        </div>
    </form>
</div>
