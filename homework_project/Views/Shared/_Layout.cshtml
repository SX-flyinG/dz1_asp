<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ProductApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #0a0a0f;
            --surface: #12121a;
            --card: #1a1a26;
            --border: #2a2a3d;
            --accent: #6c63ff;
            --accent2: #ff6584;
            --text: #e8e8f0;
            --muted: #6b6b8a;
            --success: #43d99e;
            --error: #ff5e7a;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            min-height: 100vh;
        }
        /* NAV */
        nav {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 0 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 64px;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(12px);
        }
        .nav-brand {
            font-family: 'Syne', sans-serif;
            font-size: 1.3rem;
            font-weight: 800;
            color: var(--text);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .nav-brand span {
            background: linear-gradient(135deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .nav-links { display: flex; gap: 4px; }
        .nav-links a {
            color: var(--muted);
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .nav-links a:hover { color: var(--text); background: var(--card); }
        .nav-links a.active { color: var(--accent); background: rgba(108,99,255,0.1); }
        /* MAIN */
        main { max-width: 960px; margin: 0 auto; padding: 2.5rem 1.5rem; }
        /* PAGE HEADER */
        .page-header { margin-bottom: 2rem; }
        .page-header h1 {
            font-family: 'Syne', sans-serif;
            font-size: 2rem;
            font-weight: 800;
            color: var(--text);
        }
        .page-header p { color: var(--muted); margin-top: 4px; }
        /* CARDS */
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
        }
        /* FORM */
        .form-group { margin-bottom: 1.5rem; }
        .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--muted);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .form-control {
            width: 100%;
            background: var(--surface);
            border: 1px solid var(--border);
            color: var(--text);
            padding: 12px 16px;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }
        .form-control:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(108,99,255,0.15);
        }
        textarea.form-control { resize: vertical; min-height: 100px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .field-validation-error {
            color: var(--error);
            font-size: 0.82rem;
            margin-top: 5px;
            display: block;
        }
        /* BUTTONS */
        .btn {
            padding: 12px 24px;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            font-size: 0.95rem;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }
        .btn-primary {
            background: var(--accent);
            color: #fff;
        }
        .btn-primary:hover { background: #5a52e0; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(108,99,255,0.35); }
        .btn-danger {
            background: rgba(255,94,122,0.15);
            color: var(--error);
            border: 1px solid rgba(255,94,122,0.3);
        }
        .btn-danger:hover { background: var(--error); color: #fff; }
        .btn-secondary {
            background: var(--surface);
            color: var(--muted);
            border: 1px solid var(--border);
        }
        .btn-secondary:hover { color: var(--text); border-color: var(--muted); }
        .btn-sm { padding: 7px 14px; font-size: 0.85rem; }
        /* ALERTS */
        .alert {
            padding: 14px 18px;
            border-radius: 10px;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
        }
        .alert-success { background: rgba(67,217,158,0.1); border: 1px solid rgba(67,217,158,0.3); color: var(--success); }
        .alert-error { background: rgba(255,94,122,0.1); border: 1px solid rgba(255,94,122,0.3); color: var(--error); }
        /* TABLE */
        .table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid var(--border); }
        table { width: 100%; border-collapse: collapse; }
        thead { background: var(--surface); }
        thead th {
            padding: 14px 16px;
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            text-align: left;
        }
        tbody tr { border-top: 1px solid var(--border); transition: background 0.15s; }
        tbody tr:hover { background: rgba(108,99,255,0.04); }
        td { padding: 14px 16px; font-size: 0.9rem; }
        /* BADGE */
        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.78rem;
            font-weight: 500;
        }
        .badge-blue { background: rgba(108,99,255,0.15); color: var(--accent); }
        .badge-green { background: rgba(67,217,158,0.15); color: var(--success); }
        /* PRODUCT DETAIL */
        .product-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.5rem; }
        .detail-item label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); display: block; margin-bottom: 4px; }
        .detail-item span { font-size: 1rem; color: var(--text); }
        .danger-zone {
            margin-top: 2rem;
            padding: 1.5rem;
            border: 1px solid rgba(255,94,122,0.25);
            border-radius: 12px;
            background: rgba(255,94,122,0.04);
        }
        .danger-zone h3 {
            font-family: 'Syne', sans-serif;
            color: var(--error);
            font-size: 1rem;
            margin-bottom: 0.75rem;
        }
        /* SEARCH BAR */
        .search-bar {
            display: flex;
            gap: 12px;
            align-items: center;
        }
        .search-bar .form-control { flex: 1; font-size: 1rem; padding: 14px 20px; border-radius: 12px; }
        /* EMPTY STATE */
        .empty-state { text-align: center; padding: 3rem 2rem; color: var(--muted); }
        .empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }
        .empty-state h3 { font-family: 'Syne', sans-serif; color: var(--text); margin-bottom: 0.5rem; }
        /* SEARCH RESULTS */
        .result-count { font-size: 0.9rem; color: var(--muted); margin-bottom: 1.5rem; }
        .result-count strong { color: var(--accent); }
        /* TOP BAR */
        .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
        .breadcrumb { font-size: 0.85rem; color: var(--muted); }
        .breadcrumb a { color: var(--muted); text-decoration: none; }
        .breadcrumb a:hover { color: var(--accent); }
        .breadcrumb span { margin: 0 6px; }
    </style>
</head>
<body>
    <nav>
        <a href="/Product/Index" class="nav-brand">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M3 6h18M3 12h18M3 18h18" stroke="url(#g)" stroke-width="2" stroke-linecap="round"/>
                <defs><linearGradient id="g" x1="3" y1="12" x2="21" y2="12" gradientUnits="userSpaceOnUse"><stop stop-color="#6c63ff"/><stop offset="1" stop-color="#ff6584"/></linearGradient></defs>
            </svg>
            <span>Product</span>Manager
        </a>
        <div class="nav-links">
            <a href="/Product/Index" class="@(ViewData["Active"]?.ToString() == "Index" ? "active" : "")">
                📦 Всі продукти
            </a>
            <a href="/Product/Create" class="@(ViewData["Active"]?.ToString() == "Create" ? "active" : "")">
                ➕ Додати
            </a>
            <a href="/Product/Search" class="@(ViewData["Active"]?.ToString() == "Search" ? "active" : "")">
                🔍 Пошук
            </a>
        </div>
    </nav>
    <main>
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">✅ @TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">❌ @TempData["ErrorMessage"]</div>
        }
        @RenderBody()
    </main>
</body>
</html>
